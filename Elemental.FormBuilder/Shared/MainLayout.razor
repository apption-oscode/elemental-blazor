@inherits LayoutComponentBase
@using Elemental.Code

<AeLayoutV2 Links="_navLinks">
    <Brand>
        <AeTypography Variant="h2">Form Builder</AeTypography>
    </Brand>
    <ChildContent>
        <AeTypography Variant="h1" style="text-align: center;">Form Builder</AeTypography>
        <AeFlex Vertical style="max-width: 1200px; padding: 0rem 2rem 5rem">
            @Body
        </AeFlex>
    </ChildContent>
</AeLayoutV2>



